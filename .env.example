# Bot Core Settings
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here
CLIENT_ID=your_client_id_here

# Dashboard
# If set, the dashboard (UI + /api/*) requires a login (cookie session).
DASHBOARD_PORT=2024
DASHBOARD_PASSWORD=change_me_to_a_long_random_password
DASHBOARD_SESSION_TTL=86400
# Set true only if Node is serving HTTPS directly
DASHBOARD_COOKIE_SECURE=false

# Optional: allow cross-origin API requests
# DASHBOARD_CORS_ORIGIN=https://yourdomain.com

# Bot embed theming (optional)
BOT_BRAND_NAME=Apex Bot
BOT_BRAND_COLOR=0x5865F2
