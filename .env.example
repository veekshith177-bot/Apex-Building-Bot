# Bot Core Settings
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here
CLIENT_ID=your_client_id_here

# Dashboard
# If set, the dashboard (UI + /api/*) requires HTTP Basic Auth.
DASHBOARD_PORT=2024
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_to_a_long_random_password

# Optional: allow cross-origin API requests
# DASHBOARD_CORS_ORIGIN=https://yourdomain.com
